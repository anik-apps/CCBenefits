# Copy to .env on the server and fill in values.
# Generate secrets: python3 -c "import secrets; print(secrets.token_hex(32))"

# App
CCB_SECRET_KEY=CHANGE_ME
CCB_ENV=production
CCB_ALLOWED_ORIGINS=https://yourdomain.com
DATABASE_URL=postgresql+psycopg://ccb:CHANGE_ME_DB_PASSWORD@postgres:5432/ccbenefits
FRONTEND_DIST_DIR=/app/frontend/dist

# Email (Resend — leave empty to use console logging)
# Transactional emails (verification, password reset) use noreply@
# Notification emails use notifications@ (configured in email.py)
RESEND_API_KEY=
CCB_EMAIL_FROM=CCBenefits <notifications@yourdomain.com>
CCB_FRONTEND_URL=https://yourdomain.com

# Admin
CCB_ADMIN_EMAILS=admin@yourdomain.com

# OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_IOS=
APPLE_SERVICE_ID=
APPLE_BUNDLE_ID=com.anikapps.ccbenefits
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Frontend OAuth (set in frontend/.env.local for dev, or bake into Docker build)
# VITE_GOOGLE_CLIENT_ID=<same as GOOGLE_CLIENT_ID>
# VITE_APPLE_SERVICE_ID=<same as APPLE_SERVICE_ID>

# Notification Scheduler (set to true in production)
# Runs APScheduler for email/push notifications (hourly checks)
# Requires single worker (--workers 1) to avoid duplicate execution
CCB_SCHEDULER_ENABLED=true

# Grafana Cloud (optional — leave empty to disable observability)
GRAFANA_OTLP_ENDPOINT=
GRAFANA_INSTANCE_ID=
GRAFANA_OTLP_TOKEN=

# Postgres
POSTGRES_USER=ccb
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=ccbenefits

# --- GitHub Secrets (not in .env, stored in GitHub Actions) ---
# ORACLE_VM_IP          — Oracle Cloud VM public IP
# ORACLE_SSH_USER       — SSH username (ubuntu)
# ORACLE_SSH_KEY        — SSH private key (PEM)
# GRAFANA_SA_TOKEN      — Grafana Cloud service account token (Admin role)
# GOOGLE_SERVICES_JSON  — Firebase google-services.json (EAS secret, not GitHub)
